<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_student_tree" model="ir.ui.view">
        <field name="name">academy.student.tree</field>
        <field name="model">academy.student</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="tutoring_count"/>
                <field name="last_tutoring_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_student_form" model="ir.ui.view">
        <field name="name">academy.student.form</field>
        <field name="model">academy.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="state == 'draft'" readonly="is_locked == True"/>
                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="active"/>
                        <field name="state"/>
                    </group>
                    <group string="Statistics">
                        <field name="tutoring_count"/>
                        <field name="last_tutoring_date"/>
                    </group>
                    <group string="Tutorings">
                        <field name="tutoring_ids" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>