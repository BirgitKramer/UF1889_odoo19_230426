<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tutoring_tree" model="ir.ui.view">
        <field name="name">academy.tutoring.tree</field>
        <field name="model">academy.tutoring</field>
        <field name="arch" type="xml">
            <tree string="Tutorings">
                <field name="name"/>
                <field name="date"/>
                <field name="student_id"/>
                <field name="notes"/>
            </tree>
        </field>
    </record>

    <record id="view_tutoring_form" model="ir.ui.view">
        <field name="name">academy.tutoring.form</field>
        <field name="model">academy.tutoring</field>
        <field name="arch" type="xml">
            <form string="Tutoring">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="student_id"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>